PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/MindLift Role
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
ADMIN_EMAILS=admin1@example.com,admin2@example.com
CLIENT_ORIGIN=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173
TRUST_PROXY=1
USE_CLOUD_STORAGE=false
UPLOAD_BASE_URL=http://localhost:5000
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=mindlift-role/uploads
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=MindLift <no-reply@mindlift.org>
# Optional alias if your platform sets this key instead:
# Email_From=MindLift <no-reply@mindlift.org>